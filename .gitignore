# data as data/*.db above, just under different filenames.
data/*.db-info
data/*.db-shm
data/*.db-wal
data/*.pre-turso-backup
data/tailored/

# Personal resume/CV content and generated per-company tailored output
cv/

# Python
__pycache__/
*.py[cod]
.pytest_cache/

# Virtual environment
.venv/

